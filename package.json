{
	"name": "djs-core",
	"type": "module",
	"private": true,
	"version": "6.0.0",
	"packageManager": "bun@1.3.9",
	"workspaces": [
		"packages/*",
		"plugins/*",
		"app"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@changesets/cli": "^2.30.0",
		"dts-bundle-generator": "^9.5.1",
		"knip": "^5.88.1",
		"typescript": "latest",
		"turbo": "^2.8.20"
	},
	"scripts": {
		"check": "biome check",
		"build": "turbo build types --filter=./packages/* --filter=./plugins/*",
		"dev": "turbo dev --filter=./packages/* --filter=./plugins/*",
		"types": "turbo types --filter=./packages/* --filter=./plugins/*",
		"changeset": "changeset",
		"ci:version": "changeset version && bun update",
		"ci:publish": "\"ci:publish\": \"for dir in packages/* plugins/*; do [ -d \\\"$dir\\\" ] && [ -f \\\"$dir/package.json\\\" ] && (cd \\\"$dir\\\" && PACK_FILE=$(bun pm pack | tail -n 1) && npm publish \\\"$PACK_FILE\\\" --access public --provenance || true); done && changeset tag\""
	}
}
