{
	"name": "@djs-core/runtime",
	"version": "1.8.0",
	"description": "Runtime library for djs-core Discord bot framework",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"dev": "bun build index.ts --outdir dist --target bun --external discord.js --watch",
		"build": "bun build index.ts --outdir dist --target bun --external discord.js --minify",
		"types": "dts-bundle-generator -o dist/index.d.ts index.ts --no-check --project tsconfig.json",
		"test": "bun test",
		"prepack": "turbo build types"
	},
	"dependencies": {
		"cron": "^4.4.0",
		"discord.js": "^14.25.1"
	},
	"devDependencies": {
		"typescript": "^6",
		"@types/bun": "latest",
		"dts-bundle-generator": "^9.4.0"
	},
	"files": [
		"dist"
	],
	"author": "Cleboost",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Cleboost/djs-core.git",
		"directory": "packages/runtime"
	},
	"publishConfig": {
		"access": "public"
	}
}
