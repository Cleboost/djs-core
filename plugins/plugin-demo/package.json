{
	"name": "@djs-core/plugin-demo",
	"version": "0.0.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"private": true,
	"scripts": {
		"build": "bun build index.ts --outdir dist --target bun --external @djs-core/runtime --external discord.js --minify",
		"types": "dts-bundle-generator -o dist/index.d.ts index.ts --no-check --project tsconfig.json",
		"prepack": "bun run build && bun run types"
	},
	"dependencies": {
		"@djs-core/runtime": "workspace:*"
	},
	"devDependencies": {
		"typescript": "^5",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"discord.js": "^14.25.1"
	},
	"files": [
		"dist"
	]
}
