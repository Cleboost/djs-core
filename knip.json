{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"workspaces": {
		"packages/runtime": {
			"entry": "index.ts"
		},
		"packages/dev": {
			"entry": "index.ts"
		},
		"plugins/plugin-demo": {
			"entry": "index.ts"
		},
		"plugins/plugin-prisma-sqlite": {
			"entry": "index.ts",
			"ignoreDependencies": ["prisma"]
		},
		"plugins/plugin-sql": {
			"entry": "index.ts"
		},
		"app": {
			"entry": ["djs.config.ts", "prisma.config.ts", "src/**/*.ts"],
			"ignoreDependencies": ["dotenv", "prisma"]
		}
	},
	"ignoreBinaries": [],
	"ignore": ["packages/utils/**"]
}
